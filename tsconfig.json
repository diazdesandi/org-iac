{
	"compilerOptions": {
		"strict": true,
		"outDir": "bin",
		"target": "es2020",
		"module": "esnext",
		"moduleResolution": "bundler",
		"types": ["bun"],
		"paths": {
			"@/*": ["./src/*"],
			"@config/*": ["./config/*"]
		},
		"sourceMap": true,
		"experimentalDecorators": true,
		"pretty": true,
		"noFallthroughCasesInSwitch": true,
		"noImplicitReturns": true,
		"forceConsistentCasingInFileNames": true
	},
	"include": ["**/*.ts"]
}
